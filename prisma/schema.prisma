generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          String      @default("USER")
  isBlocked     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  reviews       Review[]
  accounts      Account[]
  sessions      Session[]
  forumVotes    ForumVote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Kindergarten {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  city            String
  region          String?
  area            String?
  address         String?
  type            String   @default("valstybinis")
  phone           String?
  website         String?
  language        String?
  ageFrom         Int?
  groups          Int?
  hours           String?
  features        String   @default("[]")
  description     String?
  note            String?
  baseRating      Float    @default(0)
  baseReviewCount Int      @default(0)
  isUserAdded     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city])
  @@index([city, baseRating])
  @@index([name])
  @@index([createdAt])
}

model Aukle {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  city            String
  region          String?
  area            String?
  phone           String?
  email           String?
  experience      String?
  ageRange        String?
  hourlyRate      String?
  languages       String?
  description     String?
  availability    String?
  baseRating      Float    @default(0)
  baseReviewCount Int      @default(0)
  isServicePortal Boolean  @default(false)
  isUserAdded     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city])
  @@index([city, baseRating])
  @@index([name])
  @@index([createdAt])
}

model Burelis {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  city            String
  region          String?
  area            String?
  category        String?
  subcategory     String?
  ageRange        String?
  price           String?
  schedule        String?
  phone           String?
  website         String?
  description     String?
  baseRating      Float    @default(0)
  baseReviewCount Int      @default(0)
  isUserAdded     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city])
  @@index([city, baseRating])
  @@index([name])
  @@index([createdAt])
}

model Specialist {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  city            String
  region          String?
  area            String?
  specialty       String?
  clinic          String?
  price           String?
  phone           String?
  website         String?
  languages       String?
  description     String?
  baseRating      Float    @default(0)
  baseReviewCount Int      @default(0)
  isUserAdded     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city])
  @@index([city, baseRating])
  @@index([name])
  @@index([createdAt])
}

model Review {
  id         String   @id @default(cuid())
  itemId     String
  itemType   String
  authorName String
  rating     Int      @default(5)
  text       String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  @@unique([userId, itemId, itemType])
  @@index([itemId, itemType, isApproved])
  @@index([isApproved, createdAt])
  @@index([createdAt])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  itemId    String
  itemType  String
  sessionId String
  userId    String?
  createdAt DateTime @default(now())

  @@unique([itemId, itemType, sessionId])
}

model ForumCategory {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  icon        String?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  posts       ForumPost[]
}

model ForumPost {
  id         String         @id @default(cuid())
  title      String
  slug       String         @unique
  content    String
  authorName String
  authorId   String?
  categoryId String
  category   ForumCategory  @relation(fields: [categoryId], references: [id])
  city       String?
  upvotes    Int            @default(0)
  downvotes  Int            @default(0)
  viewCount  Int            @default(0)
  isPinned   Boolean        @default(false)
  isLocked   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  comments   ForumComment[]
  votes      ForumVote[]

  @@index([categoryId, createdAt])
  @@index([slug])
  @@index([createdAt])
  @@index([upvotes])
}

model ForumComment {
  id         String         @id @default(cuid())
  postId     String
  post       ForumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    ForumComment[] @relation("CommentReplies")
  content    String
  authorName String
  authorId   String?
  upvotes    Int            @default(0)
  downvotes  Int            @default(0)
  createdAt  DateTime       @default(now())
  votes      ForumVote[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model ForumVote {
  id        String        @id @default(cuid())
  postId    String?
  post      ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  sessionId String?
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  value     Int

  @@unique([postId, sessionId])
  @@unique([commentId, sessionId])
  @@unique([postId, userId])
  @@unique([commentId, userId])
  @@index([postId])
  @@index([commentId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}
